{
  "name": "electron-pipe-bridge",
  "version": "0.0.4",
  "description": "Lightweight IPC bridge for Electron to launch and communicate with sub-apps (.asar) via low-level system pipes (stdio 3/4).",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "jest",
    "build": "tsup",
    "prepublishOnly": "npm test && npm run build"
  },
  "jest": {
    "transform": {
      "^.+\\.ts?$": "ts-jest",
      "^.+\\.[t|j]sx?$": "babel-jest"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SergoMorello/x11-pipe.git"
  },
  "browser": {
    "child_process": false,
    "path": false,
    "fs": false
  },
  "keywords": [
    "electron",
    "ipc",
    "spawn",
    "pipe",
    "stdio",
    "asar",
    "child-process",
    "binary-stream",
    "inter-process-communication",
    "bridge",
    "sidecar",
    "multi-process",
    "stream",
    "node-js"
  ],
  "author": "Sergei Serov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SergoMorello/x11-pipe/issues"
  },
  "homepage": "https://github.com/SergoMorello/x11-pipe#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.22.9",
    "@babel/preset-typescript": "^7.22.5",
    "@types/jest": "^29.4.3",
    "babel-jest": "^29.4.3",
    "jest": "^29.4.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "electron": "^40.6.0"
  }
}
